#!/bin/bash

# Colors

RED="\e[1;31m"

GREEN="\e[1;32m"

BLUE="\e[1;34m"

P="\e[1;35m"

YELLOW="\e[1;33m"

ORANGE="\e[38;5;214m"

LB="\e[36m"

NC="\e[0m"

# Dependencies && pkg managers

pkgs=(e2fsprogs figlet)

if ! (command -v figlet >/dev/null 2>&1 && command -v chattr >/dev/null 2>&1); then
        if [[ $(command -v apt) ]]; then
                if ! apt install -y ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v pacman) ]]; then
                if ! pacman -Sy --noconfirm --needed --overwrite "*" ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v dnf) ]]; then
                if ! dnf install -y --allowerasing ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v yum) ]]; then
                if ! yum install -y figlet; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}figlet${NC}"
                exit 1
                fi
        elif [[ $(command -v xbps-install) ]]; then
                if ! xbps-install -Sy -f -y "*" ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}figlet${NC}"
                exit 1
                fi
        elif [[ $(command -v zypper) ]]; then
                if ! zypper install ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v apk) ]]; then
                if ! apk add --no-cache figlet; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v emerge) ]]; then
                if ! emerge -v --oneshot --keep-going ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        else
                echo -e "\n${RED}[${NC}-${RED}]${NC} Not common: ${RED}Unsuported pkg manager, please install: ${ORANGE}'${pkgs[@]}'${NC}"
                exit 1
        fi
fi

# Banner

echo -e "${RED}" && figlet ArchConfig
echo -n -e "${YELLOW}v1.0.0.2 ${LB}--> ${RED}Archnon's Torrc Custom Manager${NC}"
echo -e "\n"
echo -e "\n${BLUE}[${GREEN}*${BLUE}] ${GREEN}Developed By: ${ORANGE}newmasterone27@gmail.com${NC}"

# Tor Ports

TRANS=6969 # TCP Syn
DNS=5353 # Sys DNS resolution
SOCKS=9150 # .onion usage
CONTROL=9151 # new nym
HTTP=8118 # .onion link redirection

# Usage Warn

usage(){
echo -e "\n${RED}[${YELLOW}*${RED}]${GREEN} usage: ${P}archconfig ${NC}<${GREEN}action${NC}>${NC}"
echo -e "\n${BLUE}[${ORANGE}1${BLUE}]${LB} reset: ${ORANGE}Remplace Torrc with Archnon's default${NC}"
echo -e "\n${BLUE}[${ORANGE}2${BLUE}]${LB} show: ${ORANGE}Show config files${NC}"
echo -e "\n${BLUE}[${ORANGE}3${BLUE}]${LB} firewall: ${ORANGE}Show ${RED}Firewall rules.${NC}"
echo -e "\n${BLUE}[${ORANGE}4${BLUE}]${LB} load: ${ORANGE}Load ${P}custom Torrc${NC}"
echo -e "\n${BLUE}[${ORANGE}5${BLUE}]${LB} bridges: ${ORANGE}Load ${P}custom Bridges based Torrc${NC}"
}

# modes "$1"

while [ $# -gt 0 ]; do
       case $1 in

       reset)
       mode=10

       if [ $EUID -ne 0 ]; then
           echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
           exit 1
       fi

    chattr -i /etc/tor/torrc >/dev/null 2>&1

    rm /etc/tor/torrc >/dev/null 2>&1
        touch /etc/tor/torrc >/dev/null 2>&1

cat << EOT > /etc/tor/torrc
# <--- Generated by Archnon ---> #
# File locked by chattr +i, unlock: sudo chattr -i /etc/tor/torrc
CookieAuthentication 0
VirtualAddrNetworkIPv4 10.192.0.0/10
AutomapHostsOnResolve 1
AutomapHostsSuffixes .exit,.onion
TransPort 127.0.0.1:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
DNSPort 127.0.0.1:$DNS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
SocksPort 127.0.0.1:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
ControlPort 127.0.0.1:$CONTROL
HTTPTunnelPort 127.0.0.1:$HTTP
EntryNodes {is},{ch},{fi},{ro}
ExitNodes {is},{ch},{fi},{ro}
StrictNodes 1
MaxCircuitDirtiness 10
ClientUseIPv6 0
ClientPreferIPv6ORPORT 0
ClientRejectInternalAddresses 1
AvoidDiskWrites 1
EnforceDistinctSubnets 1
HardwareAccel 1
EOT
        chattr +i /etc/tor/torrc

        echo -e "\n${P}[${NC}+${P}]${NC} File Touched ${RED}(${ORANGE}/etc/tor/torrc${RED}), ${BLUE}(${GREEN}done${BLUE})${NC}"
        echo -e "\n${BLUE}[${NC}+${BLUE}]${ORANGE} Restart to apply${NC}"

        shift
        break
;;

load)
mode=11

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

file=$2

if [ -z $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Missing file${NC}"
    echo -e "\n${BLUE}[${NC}*${BLUE}]${ORANGE} usage: ${BLUE}sudo archconfig load ${YELLOW}<${NC}file${YELLOW}>${NC}"
    exit 1
fi

if [ ! -f $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}"$2"${NC}, ${RED}NO SUCH FILE${NC}"
    exit 1
fi


if [ -f /etc/tor/torrc ]; then

    chattr -i /etc/tor/torrc >/dev/null 2>&1

    rm /etc/tor/torrc >/dev/null 2>&1
    touch /etc/tor/torrc >/dev/null 2>&1

    echo -e "\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #" >> /etc/tor/torrc

    # Sorry but changing Tor prots without touching script may break its firewall logic #

    echo -e "\n# Do NOT change Tor ports, it may break script's firewall logic !! #\nTransPort 127.0.0.1:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nDNSPort 127.0.0.1:$DNS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nSocksPort 127.0.0.1:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nControlPort 127.0.0.1:$CONTROL\nHTTPTunnelPort 127.0.0.1:$HTTP" >> /etc/tor/torrc

    cat "$file" >> /etc/tor/torrc && echo -e "\n${BLUE}[${NC}*${BLUE}]${NC} File touched ${LB}'/etc/tor/torrc', ${BLUE}(${GREEN}done${BLUE})${NC}" || echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not modify: ${YELLOW}'/etc/tor/torrc'${NC}"
    chattr +i /etc/tor/torrc >/dev/null 2>&1

    if id debian-tor >/dev/null 2>&1; then
         export TOR_USER="debian-tor"
    elif id tor >/dev/null 2>&1; then
         export TOR_USER="tor"
    elif id toranon >/dev/null 2>&1; then
         export TOR_USER="toranon"
    else
        export TOR_USER=$(id 0)
    fi

    chwon -R $TOR_USER:$TOR_USER /etc/tor/torrc >/dev/null 2>&1

    if tor --verify-config >/dev/null 2>&1; then
        echo -e "\n${ORANGE}[${NC}*${ORANGE}]${GREEN} Valid, ${LB}restart Archnon to apply${NC}"
        exit 0
    else
        echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}INVALID CONFIG${NC}"
        exit 1
    fi
else
        echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}'/etc/tor/torrc'${NC}, ${RED}NO SUCH FILE${NC}"
        echo -e "\n${ORANGE}[${YELLOW}!${ORANGE}]${RED} Ensure you ran Archnon at least one time !${NC}"
        exit 1
fi

shift
break
;;

firewall)

mode=12

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

if ! [ -f /etc/archnon_rules.nft ]; then
        echo -e "\n${ORANGE}[${YELLOW}!${ORANGE}]${RED} Ensure you ran Archnon at least one time !${NC}"
        exit 1
fi

if [ -f /etc/archnon_rules.nft ]; then
    echo -e "\n${BLUE}[${NC}*${BLUE}]${LB} Showing ${GREEN}'/etc/archnon_rules.nft'${NC}, ${ORANGE}(${BLUE}skel file${ORANGE})${NC}"
    sleep 4
    cat /etc/archnon_rules.nft
    echo -e "\n${BLUE}[${NC}+${BLUE}]${GREEN} Keep Looking, take your time..${NC}"
    sleep 12
    echo -e "\n${BLUE}[${NC}*${BLUE}]${P} Showing Current firewall Rules${NC}"
    sleep 4
    nft list ruleset && echo -e "\n${ORANGE}[${NC}+${ORANGE}]${GREEN} done${NC}" || echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not show current firewall rules${NC}"
fi

shift
break

;;

show)
mode=7

if [ -f /etc/tor/torrc ] && [ -f /etc/resolv.conf ]; then
        echo -e "\n${ORANGE}[${BLUE}!${ORANGE}]${LB} Showing current ${P}Torrc${BLUE}(${YELLOW}/etc/tor/torrc${BLUE})${NC}:"
        cat /etc/tor/torrc
        echo -e "\n${ORANGE}[${BLUE}*${ORANGE}]${LB} Showing current ${BLUE}DNS${LB} config${RED}(${YELLOW}/etc/resolv.conf${RED})${NC}:"
         cat /etc/resolv.conf
         exit 0
else
        echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Not found ${ORANGE}(${YELLOW}/etc/resolv.conf, /etc/tor/torrc${ORANGE})${NC}"
        exit 1
fi
shift
break

;;

bridges)

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

mode=7
file=$2
kind=$3
bin=$4

chattr -i /etc/tor/torrc >/dev/null 2>&1
rm /etc/tor/torrc >/dev/null 2>&1
touch /etc/tor/torrc >/dev/null 2>&1

if [[ -z "$file" || ! -f "$file" || -z "$kind" || ! "$bin" || -z "$bin" ]]; then
    echo -e "\n${ORANGE}[${NC}*${ORANGE}]${P} usage: ${GREEN}sudo archconfig bridges ${BLUE}<${NC}file${BLUE}> ${BLUE}<${NC}kind${BLUE}> ${BLUE}<${NC}bin${BLUE}>${NC}"
    echo -e "\n${ORANGE}[${NC}*${ORANGE}]${P} Ex: ${GREEN}sudo archconfig bridges ${LB}bridges.txt ${LB}obfs4 ${LB}/usr/bin/obfs4proxy${NC}"
    echo -e "\n${BLUE}[${GREEN}*${BLUE}]${GREEN} File ${RED}should ONLY contain the bridges in this format: ${NC}<${YELLOW}'bridge'${NC}> ${YELLOW}<${NC}type${YELLOW}> [${NC}IP${YELLOW}]${GREEN}:${YELLOW}[${NC}PORT${YELLOW}] [${NC}fingerprint${YELLOW}] [${NC}Key=value${YELLOW}]${NC}"
    exit 1
fi

bridges=$(cat "$file")

echo -e "\n# <--- Generated by Archnon ---> #\n# Bridges Configuration #\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #\n# File locked by chattr +i, unlock: sudo chattr -i /etc/tor/torrc #\nCookieAuthentication 0\nVirtualAddrNetworkIPv4 10.192.0.0/10\nAutomapHostsOnResolve 1\nMaxCircuitDirtiness 10\nAutomapHostsSuffixes .exit,.onion\nTransPort 127.0.0.1:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nDNSPort 127.0.0.1:$DNS\nControlPort 127.0.0.1:$CONTROL\nSocksPort 127.0.0.1:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nHTTPTunnelPort 127.0.0.1:$HTTP\nClientTransportPlugin $kind exec $bin\n$bridges\nUseBridges 1\nClientUseIPv6 0\nClientPreferIPv6ORPORT 0\nClientRejectInternalAddresses 1\nHardwareAccel 1\nEnforceDistinctSubnets 1\nAvoidDiskWrites 1\n" | tee /etc/tor/torrc >/dev/null 2>&1

if tor --verify-config >/dev/null 2>&1; then
   echo -e "\n${P}[${NC}*${P}]${NC} File Touched ${BLUE}(${GREEN}done${BLUE})${NC}"
   echo -e "\n${BLUE}[${NC}*${BLUE}]${ORANGE} Restart to apply${NC}"
   chown -R $TOR_USER:$TOR_USER /etc/tor/torrc
   chown -R $TOR_USER:$TOR_USER /var/lib/tor
   chattr +i /etc/tor/torrc >/dev/null 2>&1
   exit 0
else
   echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Invalid Torrc${NC}, ${ORANGE}The fix${NC}: ${P}'archconfig reset'${NC}"
   exit 1
fi

shift
break

;;

--help|-help|help)
mode=12

usage
exit 1

shift
break

;;

--*|-*|*)
mode=6

usage
echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}unknown action: ${YELLOW}'$1'${NC}"

shift
break
exit 1

esac
done

if [ -z $mode ]; then
    usage
    exit 1
fi
